htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.pytest_cache/
.junit.xml

# -------------------------------------------------
#  Django specific
# -------------------------------------------------
# Local settings – keep them out of source control
*.local.py
settings_local.py
# Secret keys / credentials
.env
.env.*
# Database files (SQLite)
*.sqlite
*.sqlite3
*.db
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db-journal
*.db-wal
*.db-shm

# Media files uploaded by users (if you store them in the repo)
media/
# Static files generated by collectstatic
staticfiles/
# Django “migrations” that are autogenerated – keep the ones you write
# (Uncomment the line below if you truly want to ignore *all* migrations)
# **/migrations/*.py

